# Doubao (豆包) TTS API credentials
# Copy this file to scripts/.env (git-ignored) and fill in your values,
# OR add these exports directly to your ~/.zshrc.
#
# API Key:  https://console.volcengine.com/speech/new/setting/apikeys
# Voices:   https://console.volcengine.com/speech/new/voices  (filter by seed-tts-2.0)

export DOUBAO_API_KEY=your_api_key_here

# American English female (e.g. en_female_...)
export DOUBAO_SPEAKER_SAMANTHA=your_samantha_speaker_id

# British English male (e.g. en_male_...)
export DOUBAO_SPEAKER_DANIEL=your_daniel_speaker_id

# Australian English female — or any second EN female if AU isn't available
export DOUBAO_SPEAKER_KAREN=your_karen_speaker_id
