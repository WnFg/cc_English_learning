# Doubao (豆包) TTS API credentials
# Copy this file to scripts/.env (git-ignored) and fill in your values,
# OR export directly in ~/.zshrc.
#
# API Key:  https://console.volcengine.com/speech/new/setting/apikeys
# Voices:   https://console.volcengine.com/speech/new/voices  (seed-tts-2.0)

export DOUBAO_API_KEY=your_api_key_here

# Voice 1 — primary speaker (female)
export DOUBAO_SPEAKER_SAMANTHA=ICL_uranus_en_female_charlie_tob

# Voice 2 — secondary speaker (male)
export DOUBAO_SPEAKER_KAREN=ICL_uranus_en_male_michael_tob

# Voice 3 — third speaker (male)
export DOUBAO_SPEAKER_DANIEL=ICL_uranus_en_male_cartoon_chef_tob
